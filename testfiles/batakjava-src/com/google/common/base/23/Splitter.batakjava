package com.google.common.base version 23;

import java.util.regex.Pattern;

public class Splitter {
  private Strategy strategy;
  public Splitter(Strategy strategy) { this.strategy = strategy; }
  public static Splitter on(Pattern pattern) {
    return new Splitter(new Strategy());
  }
  private Splitter identity() { return new Splitter(this.strategy); }
}