package mid.utility ver 1;

import upstream.collection.Point;
/**
 *  upstream/collection/Point.overview
 *
 *  package upstream.collection ver 1;
 *  class Point extends Object;
 *  Point(float, float) in ver 1;
 *  float getX() in ver 1;
 *  float getY() in ver 1;
 *  float distance(Point) in ver 1;
 */
public class PointUtility {
         //n1
  public Point target;
                      //n2
  public PointUtility(Point target) {
       //n1        //n2
    this.target = target;
  }
          //n3
  public Point mirrorField() {
               //n4  //n1           //n1
    return new Point(target.getY(), target.geX());
  }
                 //n5        //n6
  public static Point mirror(Point p) {
               //n7  //n6      //n6
    return new Point(p.getY(), p.getX());
  }
                        //n8      //n9.
  public boolean equals(Point p1, Point p2) {
           //n8         //n9           //n8.        //n9
    return (p1.getX() == p2.getX()) && (p1.getY() == p2.getY());
  }
}