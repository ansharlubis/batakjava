package downstream.application ver 1,2;

class Main extends Object;

version 1 requires
  upstream.collection.Point version 1,
  mid.utility.* version 1,
  mid.empty.Empty version 1,2;
version 2 requires
  upstream.collection.Point version 1,2;
  mid.utility.* version 1;
  mid.empty.Empty version 1,2;

static Point createPoint(Point, Empty) in version 1,2;
static Empty createPoint(Point) in version 1,2;
static void main(String[]) in version 1,2;

//

package downstream.application;

overview of class Main {
  static Point createPoint(Point, Empty) where
    static ver1_Point createPoint_ver1(ver1_Point, ver1_Empty) in ver 1 2,
    static ver1_Point createPoint_ver1(ver1_Point, ver2_Empty) in ver 1 2,
    static ver2_Point createPoint_ver2(ver2_Point, ver1_Empty) in ver 2,
    static ver2_Point createPoint_ver2(ver2_Point, ver2_Empty) in ver 2;
  static Empty createEmpty(Empty) where
    static ver1_Empty createEmpty_ver1(ver1_Point) in ver 1 2,
    static ver2_Empty createEmpty_ver2(ver1_Point) in ver 1 2,
    static ver1_Empty createEmpty_ver1(ver2_Point) in ver 2,
    static ver2_Empty createEmpty_ver2(ver2_Point) in ver 2;
  static void main(String[]) in ver 1 2;
}