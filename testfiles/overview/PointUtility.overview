package mid.utility;
import upstream.collection.Point;

overview of class PointUtility {
  Point target where
    ver1_Point in ver 1,
    ver2_Point in ver 2;
  PointUtility(Point) where
    PointUtility(ver1_Point) in ver 1,
    PointUtility(ver2_Point) in ver 2;
  Point mirrorField() where
    ver1_Point mirrorField_ver1() in ver 1,
    ver2_Point mirrorField_ver2() in ver 2;
  static Point mirror(Point) where
    static ver1_Point mirror_ver1(ver1_Point) in ver 1,
    static ver2_Point mirror_ver2(ver2_Point) in ver 2;
  static boolean equals(Point, Point) where
    static boolean equals(ver1_Point, ver1_Point) in ver 1,
    static boolean equals(ver2_Point, ver2_Point) in ver 2;
}