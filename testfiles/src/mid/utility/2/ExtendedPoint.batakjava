package mid.utility ver 2;

import up.*;

public class ExtendedPoint extends Point {
  public ExtendedPoint(float r, float angle) {
    super(x,y);
  }
  public float distanceFromZero() {
   return new Point(0f,0f).distance(this);
  }
  public Point parent() {
    return new Point(getR(), getAngle());
  }
}