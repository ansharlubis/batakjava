  public Optional<Map<String,Integer>> ASTNode.lessMap(Map<String,Integer> mapA, Map<String,Integer> mapB) {
    boolean ongoing = false;
    boolean less = false;
    for (String varA: mapA.keySet()) {
      if (!mapB.containsKey(varA)) {
        return Optional.empty();
      }
      Integer valA = mapA.get(varA);
      Integer valB = mapB.get(varA);
      if (valA > valB) {
        if (ongoing && less) {
          return Optional.empty();
        }
        if (!ongoing) {
          ongoing = true;
        }
      } else if (valA < valB) {
        if (ongoing && !less) {
          return Optional.empty();
        }
        if (!ongoing) {
          ongoing = true;
          less = true;
        }
      }
    }
    return less ? Optional.of(mapA) : Optional.of(mapB);
  }

}