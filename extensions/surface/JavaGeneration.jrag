aspect JavaGeneration {

  syn nta TypeDecl TypeDecl.generateJava(Set<Map<String,Integer>> varToVer) = this;

  // TODO: SuperClass
  eq ClassDecl.generateJava(Set<Map<String,Integer>> varToVer) {
    return new ClassDecl(
      getModifiers(),
      getID() + "_ver" + hostVersionNum(),
      getSuperClassOpt(),
      getImplementsList(),
      getBodyDeclList()
    );
  }

}