// TODO: Implements:Access* is not yet supported
OverviewClassDecl : ClassDecl
  ::= Modifiers <ID:String> [SuperClass:Access] Implements:Access* Version* BodyDecl*
;
ExtendsVersionDecl : BodyDecl
  ::= Current:Version Superclass:Version
;
OverviewFieldDecl : FieldDecl
  ::= Version* FieldDecl*
;
OverviewConstructorDecl : ConstructorDecl
  ::= Version* ConstructorDecl*
;
OverviewMethodDecl : MethodDecl
  ::= Version* MethodDecl*
;